<% content_for :title, "Book a consultation" %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h1 class="h3 mb-4">Book a Consultation</h1>

          <%= simple_form_for @consultation, html: { class: "simple_form", data: { turbo: false } } do |f| %>
            <%= f.error_notification %>

            <div class="mb-3">
              <%= f.input :client_name,
                          required: true,
                          input_html: { class: "form-control" },
                          label: "Your name",
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :email,
                          as: :email,
                          required: false,
                          hint: "Provide at least one: email or phone number.",
                          input_html: { class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :phone_number,
                          required: false,
                          input_html: { class: "form-control" },
                          label: "Phone number",
                          hint: "Include 10 digits.",
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :address,
                          required: true,
                          input_html: { class: "form-control" },
                          label: "Property address",
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-4">
              <%= f.input :details,
                          as: :text,
                          required: true,
                          input_html: { rows: 6, class: "form-control" },
                          hint: "Please share any details about your sale, timeline, and any major items you think we should know.",
                          label_html: { class: "form-label" } %>
            </div>

            <div class="d-flex gap-2 flex-wrap">
              <%= f.button :submit, "Submit request", class: "btn btn-primary" %>
              <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
