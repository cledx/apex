<% content_for :title, "Closed consultations" %>

<div class="container py-4 pb-5">
  <div class="row mb-4 align-items-center">
    <div class="col">
      <h1 class="h3 mb-0 d-flex align-items-center gap-3 flex-wrap">
        <%= link_to "Open Consultations", manager_consultations_path, class: "btn btn-sm btn-outline-light rounded-pill px-3 py-1 small text-decoration-none" %>
        <span class="badge rounded-pill text-bg-light text-dark px-3 py-2">Closed Consultations</span>
      </h1>
    </div>
  </div>

  <% if @consultations.blank? %>
    <p class="text-white">No closed consultations yet.</p>
  <% else %>
    <% @consultations.each do |consultation| %>
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <div class="row g-4">
            <div class="col-lg-4">
              <p class="fw-bold mb-1"><%= consultation.client_name.presence || "—" %></p>
              <p class="text-muted small mb-2"><%= consultation.address %></p>
              <p class="small mb-1"><span class="fw-semibold text-body-secondary">Phone:</span> <%= consultation.phone_number %></p>
              <p class="small mb-1"><span class="fw-semibold text-body-secondary">Email:</span> <%= consultation.email.presence || "—" %></p>
              <p class="small mb-0"><span class="fw-semibold text-body-secondary">Closed:</span> <%= consultation.closed_at&.to_fs(:long) %></p>
            </div>
            <div class="col-lg-8">
              <p class="small fw-semibold text-uppercase text-secondary mb-2">Details</p>
              <div class="small p-3 bg-light rounded-3">
                <%= simple_format(consultation.details, class: "mb-0") %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>

  <p class="mt-3 mb-0">
    <%= link_to "Back to open consultations", manager_consultations_path, class: "link-light" %>
  </p>
</div>
