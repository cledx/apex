<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h1 class="h3 mb-4">Edit House</h1>

          <%= simple_form_for [:manager, @house], html: { class: "simple_form", data: { turbo: false } } do |f| %>
            <%= f.error_notification %>

            <div class="mb-3">
              <%= f.input :name,
                          input_html: { maxlength: 255, class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :owner,
                          required: true,
                          input_html: { class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :address,
                          required: true,
                          input_html: { class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :description,
                          as: :text,
                          input_html: { rows: 4, class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.input :start_date,
                            as: :date,
                            required: true,
                            input_html: { class: "form-control" },
                            label_html: { class: "form-label" } %>
              </div>
              <div class="col-md-6 mb-3">
                <%= f.input :end_date,
                            as: :date,
                            required: true,
                            input_html: { class: "form-control" },
                            label_html: { class: "form-label" } %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.input :tags,
                          input_html: { class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :total_sales,
                          as: :integer,
                          input_html: { min: 0, class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <% if @house.photos.attached? %>
              <div class="mb-3">
                <label class="form-label d-block">Current House Photos</label>
                <div class="d-flex flex-wrap gap-3">
                  <% @house.photos.each do |photo| %>
                    <div class="d-flex flex-column align-items-start gap-2">
                      <%= image_tag photo, alt: "House photo", style: "width: 110px; height: 80px; object-fit: cover;", class: "rounded border" %>
                      <div class="form-check">
                        <%= check_box_tag "house[remove_photo_ids][]", photo.id, false, id: "remove_photo_#{photo.id}", class: "form-check-input" %>
                        <%= label_tag "remove_photo_#{photo.id}", "Remove", class: "form-check-label small" %>
                      </div>
                    </div>
                  <% end %>
                </div>
                <small class="text-muted d-block mt-2">Selected photos will be deleted when you update the house.</small>
              </div>
            <% end %>

            <div class="mb-4">
              <%= f.input :photos,
                          as: :file,
                          input_html: { multiple: true, accept: "image/*", class: "form-control" },
                          label: "Add More House Photos",
                          label_html: { class: "form-label" },
                          hint: "Uploading new photos will not modify any items." %>
            </div>

            <div class="d-flex gap-2">
              <%= f.button :submit, "Update House", class: "btn btn-primary" %>
              <%= link_to "Cancel", manager_house_path(@house), class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
