<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h1 class="h3 mb-4">Create House</h1>

          <%= form_with url: new_from_url_manager_houses_path, method: :post, local: true, html: { class: "mb-4", data: { turbo: false } } do %>
            <div class="mb-3">
              <label class="form-label" for="house_import_url">Import from URL</label>
              <%= text_field_tag :url, params[:url], id: "house_import_url", class: "form-control", placeholder: "https://…", type: "url" %>
            </div>
            <%= submit_tag "Submit URL", class: "btn btn-outline-primary" %>
          <% end %>

          <%= simple_form_for [:manager, @house], html: { class: "simple_form", data: { turbo: false } } do |f| %>
            <%= f.error_notification %>

            <div class="mb-3">
              <%= f.input :name,
                          input_html: { maxlength: 255, class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :owner,
                          required: true,
                          input_html: { class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :address,
                          required: true,
                          input_html: { class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-3">
              <%= f.input :description,
                          as: :text,
                          input_html: { rows: 4, class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.input :start_date,
                            as: :date,
                            required: true,
                            input_html: { class: "form-control" },
                            label_html: { class: "form-label" } %>
              </div>
              <div class="col-md-6 mb-3">
                <%= f.input :end_date,
                            as: :date,
                            required: true,
                            input_html: { class: "form-control" },
                            label_html: { class: "form-label" } %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.input :tags,
                          input_html: { class: "form-control" },
                          label_html: { class: "form-label" } %>
            </div>

            <div class="mb-4">
              <%= f.input :photos,
                          as: :file,
                          input_html: { multiple: true, accept: "image/*", class: "form-control" },
                          label: "House Photos",
                          label_html: { class: "form-label" },
                          hint: "You can select multiple photos." %>
            </div>

            <div class="d-flex gap-2">
              <%= f.button :submit, "Create House", class: "btn btn-primary" %>
              <%= link_to "Cancel", manager_houses_path, class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
